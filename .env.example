APP_NAME="Epose AI Scanner API"
APP_VERSION="1.0.0"
ENVIRONMENT="production"
LOG_LEVEL="INFO"
CORS_ORIGINS='["*"]'

GOOGLE_APPLICATION_CREDENTIALS="/home/user/enke-ai/epose-ai/api.json"

# For Vercel, paste the complete service-account JSON as this value instead.
GOOGLE_SERVICE_ACCOUNT_JSON=""

OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3.5:4b"
OLLAMA_TIMEOUT_SECONDS=180

# Set this to use Gemini for product and invoice JSON extraction.
# If omitted, the service falls back to Ollama.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3-flash"
GEMINI_TIMEOUT_SECONDS=120

MAX_UPLOAD_BYTES=15728640
MAX_CONCURRENT_SCANS=4
